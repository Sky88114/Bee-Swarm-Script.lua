-- AUTO HIVE DETECTION
-- หา hive object จาก workspace โดยอัตโนมัติ
--==================================================
local function findHiveInWorkspace()
	local username = player.Name:lower()

	-- scan workspace top-level
	for _, obj in ipairs(workspace:GetChildren()) do
		local n = obj.Name:lower()
		-- ชื่อตรงกับ player หรือมี "hive"
		if n == username or n:find("hive") then
			local pos = nil
			if obj:IsA("BasePart") then
				pos = obj.Position
			elseif obj:IsA("Model") then
				pcall(function() pos = obj:GetPivot().Position end)
				if not pos then
					local bp = obj:FindFirstChildOfClass("BasePart")
					if bp then pos = bp.Position end
				end
			end
			if pos then
				print("🏠 Auto-found hive: "..obj.Name.." @ "..tostring(pos))
				return pos
			end
		end
	end

	-- วิธี 2: หา Part ชื่อ "HiveSlot" หรือ "ConverterZone" ใกล้ player
	local root = (function()
		local c = player.Character; if not c then return nil end
		return c:FindFirstChild("HumanoidRootPart")
	end)()

	local bestPos, bestDist = nil, math.huge
	for _, obj in ipairs(workspace:GetDescendants()) do
		local n = obj.Name:lower()
		if obj:IsA("BasePart") and (n:find("hive") or n:find("converter") or n:find("slot")) then
			local d = root and (root.Position - obj.Position).Magnitude or math.huge
			if d < bestDist and d < 30 then
				bestDist = d; bestPos = obj.Position
			end
		end
	end
	if bestPos then
		print("🏠 Found nearby hive part @ "..tostring(bestPos))
		return bestPos
	end

	return nil
end

