-- honey session ใช้ร่วมกันทั้ง WarpFarm และ Manual
local function runHoneySession(hivePos, stopFn)
	-- stopFn() = function ที่ return true เมื่อควรหยุด
	local stats = player:FindFirstChild("CoreStats")
	local pollenVal = stats and stats:FindFirstChild("Pollen")

	if pollenVal then
		local lastPollen   = pollenVal.Value
		local lastDrop     = tick()   -- ครั้งล่าสุดที่ pollen ลด
		local session      = true

		local conn = pollenVal.Changed:Connect(function(newVal)
			if newVal < lastPollen then
				lastDrop = tick()       -- pollen ลดแล้ว = bee กำลัง convert จริง
			end
			if newVal <= 0 then session = false end
			lastPollen = newVal
		end)

		-- กด E ครั้งแรกเพื่อเริ่ม
		pressE()
		task.wait(1.5)  -- รอ animation เริ่มก่อน

		while session do
			task.wait(0.5)
			if stopFn and stopFn() then break end
			local _,_,r2 = getChar(); if not r2 then break end
			if hivePos and (r2.Position-hivePos).Magnitude > 12 then break end
			if pollenVal.Value <= 0 then break end

			-- กด E ใหม่เฉพาะเมื่อ pollen ไม่ลดนาน 4 วิ (bee หยุด/cancel)
			if tick()-lastDrop >= 4 then
				pressE()
				task.wait(1.5)  -- รอ animation อีกรอบ
			end
		end

		conn:Disconnect()
	else
		-- fallback ไม่มี CoreStats
		local tStart = tick()
		pressE()
		task.wait(1.5)
		while true do
			task.wait(0.5)
			if stopFn and stopFn() then break end
			local pNow,_ = getPollen()
			if pNow <= 0 then break end
			if tick()-tStart > 180 then break end
			-- กด E ใหม่ทุก 4 วิ
			pressE()
			task.wait(1.5)
		end
	end
end

