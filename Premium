local STUCK_TIMEOUT=12; local STUCK_DIST=2.5; local WARP_CD=15
local W={anchorPos=nil,anchorTime=nil,warping=false}

local function doWarpRecovery()
	if W.warping then return end
	if (tick()-S.LastWarpTick)<WARP_CD then return end
	W.warping=true
	local hive=S.HivePos; local _,_,r=getChar()
	if hive and r then
		tweenTo(r, jitter(hive+Vector3.new(0,4,0),0.8), 0.5)
	elseif S.FieldCenter and r then
		tweenTo(r, jitter(S.FieldCenter+Vector3.new(0,4,0),1), 0.5)
	end
	S.Phase="IDLE"; S.RandomTarget=nil; S.RandomTick=0; S.LastWarpTick=tick(); S.WarpCount=S.WarpCount+1
	W.anchorPos=nil; W.anchorTime=nil
	if warpLbl and warpLbl.Parent then warpLbl.Text="🏠  Warps: "..S.WarpCount.."  |  Last: "..os.date("%H:%M:%S") end
	task.wait(1.5); W.warping=false
end

task.spawn(function()
	while true do
		task.wait(0.5)
		if not CFG.StuckWarp or W.warping then W.anchorPos=nil;W.anchorTime=nil;continue end
		local _,hum,root=getChar()
		if not root or not hum or hum.Health<=0 then W.anchorPos=nil;W.anchorTime=nil;continue end
		if S.Phase=="HONEY" or S.Phase=="WARP_HIVE" or S.Phase=="WARP_FIELD" or S.IsBoosting
			or (S.Phase=="FARM" and S.RandomTarget~=nil) then  -- กำลังเดินใน field อยู่ ไม่ใช่ stuck
			W.anchorPos=nil;W.anchorTime=nil;continue
		end
		local pos=root.Position
		if W.anchorPos==nil then W.anchorPos=pos;W.anchorTime=tick()
		elseif (pos-W.anchorPos).Magnitude>STUCK_DIST then W.anchorPos=pos;W.anchorTime=tick()
		else
			local stuckFor=tick()-W.anchorTime
			if stuckFor>4 then
				statusLbl.Text=string.format("⚠ Stuck %.0fs/%ds",stuckFor,STUCK_TIMEOUT)
				statusLbl.TextColor3=(STUCK_TIMEOUT-stuckFor)>4 and C.accentOrange or C.accentRed
			end
			if stuckFor>=STUCK_TIMEOUT then task.spawn(doWarpRecovery) end
		end
	end
end)

