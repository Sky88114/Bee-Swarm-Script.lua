local function getChar()
	local c=player.Character; if not c then return nil,nil,nil end
	return c,c:FindFirstChild("Humanoid"),c:FindFirstChild("HumanoidRootPart")
end

local function getPollen()
	for _,fname in ipairs({"CoreStats","leaderstats","BeeSwarmStats","Stats","Data"}) do
		local f=player:FindFirstChild(fname)
		if f then
			local p=f:FindFirstChild("Pollen"); local cap=f:FindFirstChild("Capacity")
			if p then return p.Value,(cap and cap.Value or 9999) end
		end
	end
	return 0,1
end

local function insideField(pos)
	if not S.Corner1 or not S.Corner2 then return false end
	return pos.X>=math.min(S.Corner1.X,S.Corner2.X) and pos.X<=math.max(S.Corner1.X,S.Corner2.X)
		and pos.Z>=math.min(S.Corner1.Z,S.Corner2.Z) and pos.Z<=math.max(S.Corner1.Z,S.Corner2.Z)
end

local function isValidToken(v)
	if not v:IsA("BasePart") then return false end
	-- เก็บเฉพาะ token ที่มองเห็นชัด (Transparency=0.00) ไม่ใช่ที่จางหายแล้ว (0.70)
	if v.Transparency > 0.1 then return false end
	if v.CanCollide == true then return false end
	-- กรอง token สูงเกิน 35 studs จาก field center Y
	if S.FieldCenter and math.abs(v.Position.Y - S.FieldCenter.Y) > 35 then return false end
	return true
end

local function allTokensInField()
	local col=workspace:FindFirstChild("Collectibles"); if not col then return {} end
	local list={}
	for _,v in ipairs(col:GetChildren()) do
		if insideField(v.Position) and isValidToken(v) then
			table.insert(list,v)
		end
	end
	return list
end

local function randomInField(y)
	if not S.Corner1 or not S.Corner2 then return nil end
	local mnX,mxX=math.min(S.Corner1.X,S.Corner2.X),math.max(S.Corner1.X,S.Corner2.X)
	local mnZ,mxZ=math.min(S.Corner1.Z,S.Corner2.Z),math.max(S.Corner1.Z,S.Corner2.Z)
	return Vector3.new(mnX+math.random()*(mxX-mnX),y,mnZ+math.random()*(mxZ-mnZ))
end

local function setPhase(ph,st,sc,mt,mc)
	S.Phase=ph
	if statusLbl and statusLbl.Parent then statusLbl.Text=st or statusLbl.Text; statusLbl.TextColor3=sc or C.textSub end
	if modeLbl and modeLbl.Parent then modeLbl.Text=mt or modeLbl.Text; modeLbl.TextColor3=mc or C.textMuted end
end

