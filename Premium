local function tw(o,p,d) return TweenService:Create(o,TweenInfo.new(d or 0.15,Enum.EasingStyle.Quad),p) end
local function jitter(v,a) a=a or 1; return v+Vector3.new((math.random()-.5)*2*a,0,(math.random()-.5)*2*a) end
local function randWait(mn,mx) task.wait(mn+math.random()*(mx-mn)) end

local function tweenTo(root, targetPos, duration)
	-- เลื่อน CFrame แบบ smooth แทน TP ตรงๆ
	duration = duration or 0.35
	local startCF = root.CFrame
	local endCF   = CFrame.new(targetPos) * (startCF - startCF.Position)
	local t0 = tick()
	while true do
		local alpha = math.min((tick()-t0)/duration, 1)
		-- ease in-out quad
		local e = alpha < 0.5 and 2*alpha*alpha or 1-(-2*alpha+2)^2/2
		pcall(function()
			root.CFrame = startCF:Lerp(endCF, e)
		end)
		if alpha >= 1 then break end
		task.wait(0.016) -- ~60fps
	end
end

