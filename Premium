-- REMOTE DISCOVERY
--==================================================
local RE = {Honey=nil, Collect=nil, Booster=nil}

local function discoverRemotes()
	local events = ReplicatedStorage:FindFirstChild("Events")
	if events then
		-- ใช้ชื่อตรงๆ จาก scan
		RE.Collect = events:FindFirstChild("ToolCollect")
		RE.Honey   = events:FindFirstChild("NectarCondenser")
		            or events:FindFirstChild("MakeHoney")
		            or events:FindFirstChild("HiveConvert")
		-- scan หา booster
		for _, r in ipairs(events:GetChildren()) do
			local n = r.Name:lower()
			if not RE.Booster and n:find("boost") then RE.Booster = r end
			if not RE.Honey and (n:find("honey") or n:find("convert") or n:find("nectar")) then RE.Honey = r end
		end
	end
	-- fallback: scan ทั้งหมด
	if not RE.Collect or not RE.Honey then
		for _, r in ipairs(ReplicatedStorage:GetDescendants()) do
			if not r:IsA("RemoteEvent") then continue end
			local n = r.Name:lower()
			if not RE.Collect and (n=="toolcollect" or n:find("collect") or n=="petalcollected") then RE.Collect=r end
			if not RE.Honey and (n:find("nectar") or n:find("honey") or n:find("convert")) then RE.Honey=r end
			if not RE.Booster and n:find("boost") then RE.Booster=r end
		end
	end
	print(string.format("🔌 Collect=%s | Honey=%s",
		RE.Collect and RE.Collect.Name or "NIL❌",
		RE.Honey   and RE.Honey.Name   or "NIL❌"))
end
task.spawn(function() task.wait(2); discoverRemotes() end)

local function safeFireServer(remote,...)
	if not remote or not remote.Parent then return false end
	local args = {...}
	return pcall(function() remote:FireServer(table.unpack(args)) end)
end

