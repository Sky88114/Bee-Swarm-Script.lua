local FIELD_DATA = {}

local function buildFieldData()
	-- สร้างจาก REAL_POSITIONS ก่อน (ค่าจริงจาก scan)
	for _,fname in ipairs(FIELD_ORDER) do
		local m = FIELD_META[fname]
		local rp = REAL_POSITIONS[fname]
		if m then
			local entry = {name=fname, icon=m.icon, pollen=m.pollen, group=m.group, fromWS=rp~=nil}
			if rp then
				entry.center = Vector3.new(rp.cx, rp.cy, rp.cz)
				entry.c1     = Vector3.new(rp.cx-rp.hx, rp.cy, rp.cz-rp.hz)
				entry.c2     = Vector3.new(rp.cx+rp.hx, rp.cy, rp.cz+rp.hz)
			end
			table.insert(FIELD_DATA, entry)
		end
	end
end
buildFieldData()

local function scanFields()
	-- override ด้วยค่า live จาก workspace ถ้าเจอ
	local fz = workspace:FindFirstChild("FlowerZones")
	local found = 0
	if not fz then
		print("⚠ FlowerZones not found in workspace"); return 0
	end
	for _, obj in ipairs(fz:GetChildren()) do
		local pos = nil
		if obj:IsA("BasePart") then
			pos = obj.Position
		elseif obj:IsA("Model") then
			pcall(function() pos = obj:GetPivot().Position end)
			if not pos then
				local bp = obj:FindFirstChildOfClass("BasePart")
				if bp then pos = bp.Position end
			end
		end
		if pos then
			-- หา field ใน FIELD_DATA ที่ตรงชื่อ
			for _, fd in ipairs(FIELD_DATA) do
				if fd.name == obj.Name then
					local hx = 40; local hz = 40
					-- ถ้า object มี Size ให้ใช้เลย
					if obj:IsA("BasePart") then
						hx = obj.Size.X/2 + 2
						hz = obj.Size.Z/2 + 2
					end
					local groundY = pos.Y + 4
					fd.center  = Vector3.new(pos.X, groundY, pos.Z)
					fd.c1      = Vector3.new(pos.X-hx, groundY, pos.Z-hz)
					fd.c2      = Vector3.new(pos.X+hx, groundY, pos.Z+hz)
					fd.fromWS  = true
					found += 1
					break
				end
			end
		end
	end
	print(string.format("✅ Re-scan: %d fields updated from workspace", found))
	return found
end

task.spawn(function() task.wait(3); scanFields() end)

