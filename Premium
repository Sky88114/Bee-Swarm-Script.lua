task.spawn(function()
	while true do
		task.wait(0.2)
		if not CFG.WarpFarm then
			if S.Phase~="IDLE" then setPhase("IDLE","◉  Ready",C.accentGreen,"Phase: Idle",C.textMuted) end
			continue
		end
		if S.IsBoosting then continue end

		local _,hum,root=getChar()
		if not root or not hum or hum.Health<=0 then continue end

		local pollen,cap=getPollen()
		local hive=S.HivePos
		local fieldPt=S.FieldCenter

		if not fieldPt then
			setPhase("IDLE","⚠ Select a Field",C.accentOrange,"Waiting: No Field",C.accentOrange); continue
		end

		if S.Phase=="IDLE" or S.Phase=="WARP_FIELD" then
			setPhase("WARP_FIELD","🚀 TP → Field",C.neon,"Phase: Warp→Field",C.textSub)
			tweenTo(root, jitter(fieldPt+Vector3.new(0,4,0),2), 0.4)
			randWait(0.3,0.6)
			S.RandomTarget=nil; S.RandomTick=0
			setPhase("FARM","📦 Farming...",C.accentGreen,"Phase: Farm",C.accentGreen)

		elseif S.Phase=="FARM" then
			if cap>0 and pollen>=cap then
				if not hive then
					setPhase("IDLE","⚠ Set Hive first",C.accentOrange,"Waiting: No Hive",C.accentOrange); continue
				end
				setPhase("WARP_HIVE","🚀 Pollen Full → Hive",C.accentOrange,"Phase: Warp→Hive",C.accentOrange)
				tweenTo(root, jitter(hive+Vector3.new(0,3,0),0.5), 0.4)
				continue
			end

			local tokens=allTokensInField()
			if #tokens>0 then
				table.sort(tokens,function(a,b)
					return (root.Position-a.Position).Magnitude<(root.Position-b.Position).Magnitude
				end)
				local batch=math.min(6,#tokens)
				for idx=1,batch do
					local t=tokens[idx]
					if not t or not t.Parent or t.Transparency>0.1 then continue end
					local _,h2,r2=getChar(); if not r2 or not h2 or h2.Health<=0 then break end
					if not CFG.WarpFarm then break end
					local pNow,cNow=getPollen(); if cNow>0 and pNow>=cNow then break end
					tweenTo(r2, jitter(t.Position+Vector3.new(0,2.5,0),0.3), 0.25)
					if RE.Collect then safeFireServer(RE.Collect) end
					randWait(0.05,0.12)
				end
				local pNow,cNow=getPollen()
				setPhase("FARM",string.format("📦 %d tokens  %d/%d",#tokens,pNow,cNow),C.accentGreen,"Phase: Farm",C.accentGreen)
			else
				-- ไม่มี token → เดินใน field จริงๆ
				local _,hum2,root2=getChar()
				if hum2 and root2 then
					local needNew = S.RandomTick > 15
						or (S.RandomTarget == nil)
						or (S.RandomTarget and (root2.Position-S.RandomTarget).Magnitude < 4)
					if needNew then
						S.RandomTarget = randomInField(root2.Position.Y)
						S.RandomTick = 0
					end
					if S.RandomTarget then
						hum2:MoveTo(S.RandomTarget)
						local moveStart = tick()
						local arrived = false
						while not arrived do
							task.wait(0.1)
							local _,_,rr = getChar(); if not rr then break end
							if not CFG.WarpFarm then break end
							if #allTokensInField() > 0 then break end
							local pN,cN = getPollen()
							if cN > 0 and pN >= cN then break end
							if (rr.Position-S.RandomTarget).Magnitude < 4 then arrived=true; break end
							if tick()-moveStart > 3 then break end
						end
						S.RandomTick = S.RandomTick + 1
					end
				end
				local pNow,cNow=getPollen()
				setPhase("FARM",string.format("🚶 Walking  %d/%d",pNow,cNow),C.neon,"Phase: Farm→Walk",C.textSub)
			end

		elseif S.Phase=="WARP_HIVE" then
			if not hive then setPhase("WARP_FIELD","↩ Back to Field",C.neon,"Phase: Warp→Field",C.textSub); continue end
			if (root.Position-hive).Magnitude>6 then
				tweenTo(root, jitter(hive+Vector3.new(0,3,0),0.4), 0.35)
				continue
			end
			setPhase("HONEY","🍯 Making Honey...",C.accentOrange,"Phase: Honey",C.accentOrange)

			runHoneySession(hive, function()
				return not CFG.WarpFarm
			end)

			honeySessions=honeySessions+1; farmCycles=farmCycles+1
			cycleLbl.Text="Cycles: "..farmCycles; honeyLbl.Text="Honey sessions: "..honeySessions
			setPhase("WARP_FIELD","🚀 Back to Field",C.neon,"Phase: Warp→Field",C.textSub)
		end
	end
end)

