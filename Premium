		if isOn then
			tw(b,{BackgroundColor3=Color3.fromRGB(0,30,55)},0.15):Play()
			local st=b:FindFirstChildOfClass("UIStroke"); if st then tw(st,{Color=C.neon},0.15):Play() end
			b.TextColor3=C.textNeon; b.Text="  ●  "..(onT or text).."  :  ON"
			tw(pill,{BackgroundColor3=C.neon},0.15):Play(); pt.TextColor3=C.bg; pt.Text="ON"
		else
			tw(b,{BackgroundColor3=C.btnDefault},0.15):Play()
			local st=b:FindFirstChildOfClass("UIStroke"); if st then tw(st,{Color=Color3.fromRGB(20,35,60)},0.15):Play() end
